{
  "name": "@nijam/vitest-reporter",
  "version": "0.1.1",
  "description": "Vitest reporter for Nijam, captures test runs and ships them to the Nijam API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nijam-vitest": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vitest",
    "reporter",
    "nijam",
    "test-analytics",
    "flaky-tests"
  ],
  "homepage": "https://nijam.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getnijam/vitest-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/getnijam/vitest-reporter/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "release": "pnpm build && pnpm publish --access public"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
